{
  "name": "@iexec-nox/nox-confidential-contracts",
  "version": "0.0.0",
  "description": "Nox confidential smart contracts",
  "keywords": [
    "Nox",
    "Confidential DeFi",
    "cDeFi"
  ],
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "files": [
    "/contracts"
  ],
  "scripts": {
    "prepare": "husky",
    "clean": "pnpm hardhat clean",
    "build": "pnpm hardhat build",
    "test": "pnpm hardhat test",
    "coverage": "pnpm hardhat test --coverage",
    "format": "pnpm prettier --write .",
    "format:check": "pnpm prettier --check ."
  },
  "lint-staged": {
    "*.{sol,js,ts,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.0.7",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.2",
    "@types/node": "^22.19.10",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.1.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-plugin-solidity": "^2.2.1",
    "typescript": "~5.8.0",
    "viem": "^2.45.2"
  },
  "homepage": "https://github.com/iExec-Nox/nox-confidential-contracts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iExec-Nox/nox-confidential-contracts.git"
  },
  "bugs": {
    "url": "https://github.com/iExec-Nox/nox-confidential-contracts/issues"
  },
  "dependencies": {
    "@iexec-nox/nox-protocol-contracts": "0.1.0-beta.5",
    "@openzeppelin/contracts": "^5.4.0"
  }
}