# ─── pnpm ─────────────────────────────────────────────────────────────────────

# Block lifecycle scripts from dependencies only (postinstall, install, preinstall).
# Our own prepare script is still executed after installation.
ignore-dep-scripts=true

# Reject packages published less than 3 days ago (4320 min).
# Guards against "package hijacking" attacks where a malicious version is quickly
# spread before the community can react.
minimum-release-age=4320
minimum-release-age-exclude[]="@iexec-nox/nox-protocol-contracts"

# Block transitive dependencies from using exotic specifiers (git:, file:, etc.).
# Ensures every transitive dep resolves from the registry.
block-exotic-subdeps=true
